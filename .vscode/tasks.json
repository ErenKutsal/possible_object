{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "main",
            "command": "clang++",
            "args": [
                "-std=c++11",
                "-DGL_SILENCE_DEPRECATION",
                "${workspaceFolder}/main.cpp",
                "${workspaceFolder}/InitShader.cpp",
                "-I/opt/homebrew/include",
                "-L/opt/homebrew/lib",
                "-o",
                "${workspaceFolder}/posible.out",
                "-framework",
                "OpenGL",
                "-lglfw",
                "-lGLEW"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Custom build task including Homebrew paths and silencing Apple warnings."
        },
        {
            "type": "shell",
            "label": "main2",
            "command": "clang++",
            "args": [
                "-std=c++11",
                "-DGL_SILENCE_DEPRECATION",
                "${workspaceFolder}/main2.cpp",
                "${workspaceFolder}/InitShader.cpp",
                "-I/opt/homebrew/include",
                "-L/opt/homebrew/lib",
                "-o",
                "${workspaceFolder}/imposible.out",
                "-framework",
                "OpenGL",
                "-lglfw",
                "-lGLEW"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Custom build task including Homebrew paths and silencing Apple warnings."
        }
    ]
}